{% extends 'base/base.html.twig' %}

{% block seo %}
{% include ("seo/seo_live_result.html.twig") %}
{% endblock %}

{% block body %}
    <div class="container mt-3">
        <h1 class="h3">
            {{ event.getTitle }}
        </h1>
        <p>{{ event.getDescription }}</p>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">
                🔄 Оновлення через: <b><span id="refresh-timer">5</span> сек</b>
            </small>
            <small class="text-success font-weight-bold live-text">LIVE</small>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="form-group mb-3 d-flex align-items-center">
                    <label for="filter-select" class="mb-0 me-2"><b>Фільтр за класом: &nbsp;</b></label>
                    <select id="filter-select" class="form-control form-control-sm w-auto">
                        {% for key, value in filter %}
                            <option value="{{ key }}" {% if selectedFilter == key %}selected{% endif %}>
                                {{ value }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <input type="hidden" id="event-id" value="{{ id }}">
                <input type="hidden" id="csrf-token" value="{{ csrf_token('live_event') }}">

                <div id="live-container">
                    {% include 'result/live_table.html.twig' %}
                </div>

            </div>
        </div>
    </div>

    {# ================= CSS для подсветки активной строки ================= #}
    <style>
        .leaderboard-table tr.active-row {
            background-color: #e7f1ff !important;
            transition: background-color 0.2s ease;
        }
    </style>

    {# ================= JS для раскрытия и подсветки ================= #}
    <script src="{{ asset('assets/script/live.js') }}?ver=0.0.3"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        // массив открытых строк
        let openedRows = [];
        $(document).ready(function() {

            // Фильтр
            $('#filter-select').change(function() {
                var selectedValue = $(this).val();
                var currentUrl = window.location.href.split('?')[0];
                window.location.href = currentUrl + '?filter=' + selectedValue;
            });

            // Раскрытие деталей (мульти-открытие)
            $(document).on('click', '.toggle-details', function () {

                const id = $(this).data('id');
                const row = $('#details-' + id);
                const icon = $(this).find('.toggle-icon');
                const mainRow = $('tr.main-row[data-id="' + id + '"]');

                if (row.is(':visible')) {

                    row.hide();
                    icon.text('+');
                    mainRow.removeClass('active-row');

                    // удаляем из массива
                    openedRows = openedRows.filter(item => item != id);

                } else {

                    row.show();
                    icon.text('–');
                    mainRow.addClass('active-row');

                    // добавляем в массив (если нет)
                    if (!openedRows.includes(id)) {
                        openedRows.push(id);
                    }
                }
            });

        });
    </script>
{% endblock %}

{% block footer %}
    {% include ('base/footer.html.twig') %}
{% endblock %}