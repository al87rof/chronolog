{% extends 'base/base.html.twig' %}

{% block seo %}
    {% include 'seo/seo_events.html.twig' %}
{% endblock %}

{% block body %}
    <div class="container py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h2 class="fw-bold mb-0">Події</h2>

            <input type="text"
                   id="searchInput"
                   class="form-control w-auto"
                   placeholder="Пошук події...">
        </div>


        <!-- Grid -->
        <div class="row g-4" id="eventsGrid">

            {% for event in events %}
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3 event-item"
                     data-name="{{ event.getName|lower }}"
                     data-desc="{{ event.getDescription|default('')|lower }}">

                    <a href="{{ url('result', {'id': event.getHash}) }}"
                       class="event-card text-decoration-none text-dark">

                        <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">

                            <!-- Image -->
                            <div class="event-img-wrapper">
                                <img src="{{ event.getEventImg }}"
                                     class="card-img-top event-img"
                                     alt="{{ event.getName }}">
                            </div>

                            <div class="card-body d-flex flex-column">

                                <!-- Title -->
                                <h5 class="card-title fw-semibold mb-2">
                                    {{ event.getName }}
                                </h5>

                                <!-- Description -->
                                {% if event.getDescription %}
                                    <p class="text-muted small flex-grow-1">
                                        {{ event.getDescription|slice(0,120) ~ '...' }}
                                    </p>
                                {% endif %}

                                <!-- Meta -->
                                <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">

                                <span>
                                    👁 {{ event.getCount|default(0) }}
                                </span>

                                    {% if event.getDate %}
                                        <span class="badge bg-light text-dark border">
                                        {{ event.getDate|date("d.m.Y") }}
                                    </span>
                                    {% endif %}

                                </div>

                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}

        </div>

        <!-- No results -->
        <div id="noResults" class="text-center py-5 d-none">
            <h5 class="text-muted">Нічого не знайдено 😔</h5>
        </div>

    </div>

    <script src="{{ asset('assets/script/search_event.js') }}"></script>
{% endblock %}
