{% extends 'base/base.html.twig' %}

{% block seo %}
    {% include 'seo/seo_rider.html.twig' %}
{% endblock %}

{% block style %}
    <link rel="stylesheet" href="{{ asset('assets/style.css') }}?ver=0.02">
    <link rel="stylesheet" href="{{ asset('assets/style_rider.css') }}?ver=0.02">
{% endblock %}

{% block body %}
    <div class="container py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h2 class="fw-bold mb-0">{{ rider.getName }} - статистика та результати гонок</h2>

        </div>

        <div class="row g-3 mb-4 rider-stats">

            <!-- Старты -->
            <div class="col-4">
                <div class="stat-card text-center h-100">
                    <div class="stat-value"> {{ starts }} </div>
                    <div class="stat-label">Стартів</div>
                </div>
            </div>

            <!-- Финиши -->
            <div class="col-4">
                <div class="stat-card text-center h-100">
                    <div class="stat-value">
                        {{ finishes }}
                        <span class="stat-percent">
                    ( {{ finishPercent }} %)
                </span>
                    </div>
                    <div class="stat-label">Фінішів</div>
                </div>
            </div>

            <!-- Средняя позиция -->
            <div class="col-4">
                <div class="stat-card text-center h-100">
                    <div class="stat-value">{{ avgPosition }} </div>
                    <div class="stat-label">Сер. позиція</div>
                </div>
            </div>

        </div>

        {% include 'rider/awards.html.twig' %}

        <div class="row g-4">

            {% for index,event in events %}

                <div class="col-12 col-md-6 col-xl-4">
                    {% set eventRider = eventsRiders[index] %}
                    <a href="{{ url('result', {'id': event.getHash,'filter':eventRider.getRiderClass }) }}"
                       class="event-card text-decoration-none text-dark">

                        <div class="card border-0 shadow-sm h-100">

                            <!-- IMAGE -->
                            <div class="event-img-wrapper">
                                {% if event.getEventImg %}
                                    <img src="{{ event.getEventImg }}" class="event-img" alt="{{ event.name }}">
                                {% endif %}
                            </div>

                            <div class="card-body">

                                <!-- Название -->
                                <div class="fw-bold mb-1">{{ event.name }}</div>

                                <!-- Номер -->
                                {% if event %}
                                    <div class="small text-muted">Номер: #{{ eventRider.getNumber }} </div>
                                {% endif %}

                                <!-- Класс -->
                                {% if event %}
                                    <div class="small text-muted">Клас: {{ eventRider.getClass }} </div>
                                {% endif %}

                                <!-- Статус -->
                                {% if event %}
                                    <div class="small text-muted">Статус: {{ eventRider.getStatus }} </div>
                                {% endif %}

                                <!-- Позиция -->
                                {% if event%}
                                    <div class="small text-muted">Позиція: {{ eventRider.getPosition }}</div>
                                {% endif %}

                            </div>

                        </div>
                    </a>

                </div>

            {% endfor %}

        </div>

    </div>
{% endblock %}
