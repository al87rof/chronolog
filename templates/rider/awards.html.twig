{# ===== Awards Block ===== #}

        {% set hasAwards = false %}

        {% for eventRider in eventsRiders %}
            {% if eventRider.getPosition in [1,2,3] %}
                {% set hasAwards = true %}
            {% endif %}
        {% endfor %}

        {% if hasAwards %}

            <div class="awards-block mb-4">

                <h4 class="fw-bold mb-3">Нагороди</h4>

                <div class="row g-3">

                    {% for index,event in events %}
                        {% set eventRider = eventsRiders[index] %}
                        {% if  eventRider.getPosition in [1,2,3] %}

                            <div class="col-6 col-md-4 col-xl-3">

                                <div class="award-card text-center h-100">

                                    <!-- Кубок -->
                                    <div class="award-cup place-{{ eventRider.getPosition }}">

                                        {% if eventRider.getPosition == 1 %}
                                            🏆
                                        {% elseif eventRider.getPosition == 2 %}
                                            🥈
                                        {% elseif eventRider.getPosition == 3 %}
                                            🥉
                                        {% endif %}

                                    </div>

                                    <!-- Место -->
                                    <div class="award-place">
                                        {{ eventRider.getPosition }} місце
                                    </div>

                                    <!-- Название евента -->
                                    <div class="award-event">
                                        {{ event.name }}
                                    </div>

                                </div>

                            </div>

                        {% endif %}
                    {% endfor %}

                </div>

            </div>

        {% endif %}